<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface"
    android:padding="@dimen/dim_16">

    <ImageButton
        android:id="@+id/homeSettingsButton"
        android:layout_width="@dimen/home_settings_button_size"
        android:layout_height="@dimen/home_settings_button_size"
        android:background="@drawable/bg_map_control_chip"
        android:contentDescription="@string/settings_title"
        android:elevation="@dimen/dim_6"
        android:padding="@dimen/dim_12"
        android:scaleType="fitCenter"
        android:tint="@color/map_control_settings_icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_settings_gear" />

    <ImageView
        android:id="@+id/homeLogo"
        android:layout_width="@dimen/logo_width_home"
        android:layout_height="@dimen/logo_height_home"
        android:layout_marginTop="@dimen/dim_16"
        android:contentDescription="@string/drivest_logo_content_description"
        android:src="@drawable/drivest_logo_tight"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/homeStatusCard"
        android:layout_width="@dimen/dim_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dim_12"
        app:cardBackgroundColor="@color/app_card_bg"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardElevation="@dimen/dim_2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/homeLogo">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/dim_12">

            <TextView
                android:id="@+id/homeSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/home_subtitle"
                android:textColor="@color/settings_text_primary"
                android:textSize="@dimen/text_16" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_6"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/homeDriverModeValue"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/home_driver_mode_default"
                    android:textColor="@color/settings_text_secondary"
                    android:textSize="@dimen/text_13" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dim_6"
                    android:text="|"
                    android:textColor="@color/settings_text_muted"
                    android:textSize="@dimen/text_12" />

                <TextView
                    android:id="@+id/homeConfidenceValue"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/home_confidence_score_default"
                    android:textColor="@color/settings_text_secondary"
                    android:textSize="@dimen/text_13" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dim_6"
                    android:text="|"
                    android:textColor="@color/settings_text_muted"
                    android:textSize="@dimen/text_12" />

                <TextView
                    android:id="@+id/homeTheoryReadinessValue"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/home_theory_readiness_default"
                    android:textColor="@color/settings_text_secondary"
                    android:textSize="@dimen/text_13" />
            </LinearLayout>

            <TextView
                android:id="@+id/homeRecommendedLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_10"
                android:text="@string/home_recommended_today_label"
                android:textColor="@color/settings_accent"
                android:textSize="@dimen/text_12"
                android:visibility="gone" />

            <TextView
                android:id="@+id/homeRecommendedValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_3"
                android:textColor="@color/settings_text_primary"
                android:textSize="@dimen/text_13"
                android:visibility="gone" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/homeModulesHeader"
        android:layout_width="@dimen/dim_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dim_12"
        android:text="@string/home_modules_heading"
        android:textColor="@color/settings_text_primary"
        android:textSize="@dimen/text_14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/homeStatusCard" />

    <LinearLayout
        android:id="@+id/homeModeRow"
        android:layout_width="@dimen/dim_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dim_12"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/homeModulesHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/dim_0"
                android:layout_height="@dimen/dim_116"
                android:layout_marginEnd="@dimen/dim_6"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/app_card_bg"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/dim_2">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="@dimen/dim_12">

                        <ImageView
                            android:layout_width="@dimen/dim_24"
                            android:layout_height="@dimen/dim_24"
                            android:contentDescription="@string/home_practice_button"
                            android:src="@drawable/ic_home_practice" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_8"
                            android:text="@string/home_practice_button"
                            android:textColor="@color/settings_text_primary"
                            android:textSize="@dimen/text_14" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_4"
                            android:text="@string/home_practice_helper"
                            android:textColor="@color/settings_text_secondary"
                            android:textSize="@dimen/text_12" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/practiceModeButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:insetLeft="@dimen/dim_0"
                        android:insetTop="@dimen/dim_0"
                        android:insetRight="@dimen/dim_0"
                        android:insetBottom="@dimen/dim_0"
                        android:minHeight="@dimen/dim_0"
                        android:minWidth="@dimen/dim_0"
                        android:text=""
                        android:textAllCaps="false"
                        android:textColor="@android:color/transparent" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/dim_0"
                android:layout_height="@dimen/dim_116"
                android:layout_marginStart="@dimen/dim_6"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/app_card_bg"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/dim_2">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="@dimen/dim_12">

                        <ImageView
                            android:layout_width="@dimen/dim_24"
                            android:layout_height="@dimen/dim_24"
                            android:contentDescription="@string/home_navigation_button"
                            android:src="@drawable/ic_home_navigation" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_8"
                            android:text="@string/home_navigation_button"
                            android:textColor="@color/settings_text_primary"
                            android:textSize="@dimen/text_14" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_4"
                            android:text="@string/home_navigation_helper"
                            android:textColor="@color/settings_text_secondary"
                            android:textSize="@dimen/text_12" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/navigationModeButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:insetLeft="@dimen/dim_0"
                        android:insetTop="@dimen/dim_0"
                        android:insetRight="@dimen/dim_0"
                        android:insetBottom="@dimen/dim_0"
                        android:minHeight="@dimen/dim_0"
                        android:minWidth="@dimen/dim_0"
                        android:text=""
                        android:textAllCaps="false"
                        android:textColor="@android:color/transparent" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeExtraButtonsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/homeTheoryTileContainer"
                android:layout_width="@dimen/dim_0"
                android:layout_height="@dimen/dim_116"
                android:layout_marginEnd="@dimen/dim_6"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/app_card_bg"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/dim_2">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="@dimen/dim_12">

                        <ImageView
                            android:layout_width="@dimen/dim_24"
                            android:layout_height="@dimen/dim_24"
                            android:contentDescription="@string/home_theory_button"
                            android:src="@drawable/ic_home_theory" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_8"
                            android:text="@string/home_theory_button"
                            android:textColor="@color/settings_text_primary"
                            android:textSize="@dimen/text_14" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_4"
                            android:text="@string/home_theory_helper"
                            android:textColor="@color/settings_text_secondary"
                            android:textSize="@dimen/text_12" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/homeTheoryProgressBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="@dimen/dim_8"
                        android:layout_marginEnd="@dimen/dim_8"
                        android:background="@drawable/bg_app_chip"
                        android:paddingStart="@dimen/dim_6"
                        android:paddingTop="@dimen/dim_3"
                        android:paddingEnd="@dimen/dim_6"
                        android:paddingBottom="@dimen/dim_3"
                        android:text="@string/home_theory_progress_default"
                        android:textColor="@color/app_chip_text"
                        android:textSize="@dimen/text_10" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/theoryModeButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:insetLeft="@dimen/dim_0"
                        android:insetTop="@dimen/dim_0"
                        android:insetRight="@dimen/dim_0"
                        android:insetBottom="@dimen/dim_0"
                        android:minHeight="@dimen/dim_0"
                        android:minWidth="@dimen/dim_0"
                        android:text=""
                        android:textAllCaps="false"
                        android:textColor="@android:color/transparent" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/dim_0"
                android:layout_height="@dimen/dim_116"
                android:layout_marginStart="@dimen/dim_6"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/app_card_bg"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/dim_2">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="@dimen/dim_12">

                        <ImageView
                            android:layout_width="@dimen/dim_24"
                            android:layout_height="@dimen/dim_24"
                            android:contentDescription="@string/home_traffic_signs_button"
                            android:src="@drawable/ic_home_traffic_signs" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_8"
                            android:text="@string/home_traffic_signs_button"
                            android:textColor="@color/settings_text_primary"
                            android:textSize="@dimen/text_14" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_4"
                            android:text="@string/home_traffic_signs_helper"
                            android:textColor="@color/settings_text_secondary"
                            android:textSize="@dimen/text_12" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/trafficSignsModeButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:insetLeft="@dimen/dim_0"
                        android:insetTop="@dimen/dim_0"
                        android:insetRight="@dimen/dim_0"
                        android:insetBottom="@dimen/dim_0"
                        android:minHeight="@dimen/dim_0"
                        android:minWidth="@dimen/dim_0"
                        android:text=""
                        android:textAllCaps="false"
                        android:textColor="@android:color/transparent" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeBottomButtonsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/dim_0"
                android:layout_height="@dimen/dim_116"
                android:layout_marginEnd="@dimen/dim_6"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/app_card_bg"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/dim_2">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="@dimen/dim_12">

                        <ImageView
                            android:layout_width="@dimen/dim_24"
                            android:layout_height="@dimen/dim_24"
                            android:contentDescription="@string/home_highway_code_button"
                            android:src="@drawable/ic_home_traffic_signs" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_8"
                            android:text="@string/home_highway_code_button"
                            android:textColor="@color/settings_text_primary"
                            android:textSize="@dimen/text_14" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_4"
                            android:text="@string/home_highway_code_helper"
                            android:textColor="@color/settings_text_secondary"
                            android:textSize="@dimen/text_12" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/highwayCodeModeButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:insetLeft="@dimen/dim_0"
                        android:insetTop="@dimen/dim_0"
                        android:insetRight="@dimen/dim_0"
                        android:insetBottom="@dimen/dim_0"
                        android:minHeight="@dimen/dim_0"
                        android:minWidth="@dimen/dim_0"
                        android:text=""
                        android:textAllCaps="false"
                        android:textColor="@android:color/transparent" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/dim_0"
                android:layout_height="@dimen/dim_116"
                android:layout_marginStart="@dimen/dim_6"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/app_card_bg"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/dim_2">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="@dimen/dim_12">

                        <ImageView
                            android:layout_width="@dimen/dim_24"
                            android:layout_height="@dimen/dim_24"
                            android:contentDescription="@string/home_analytics_button"
                            android:src="@drawable/ic_home_analytics" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_8"
                            android:text="@string/home_analytics_button"
                            android:textColor="@color/settings_text_primary"
                            android:textSize="@dimen/text_14" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_4"
                            android:text="@string/home_analytics_helper"
                            android:textColor="@color/settings_text_secondary"
                            android:textSize="@dimen/text_12" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/analyticsModeButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:insetLeft="@dimen/dim_0"
                        android:insetTop="@dimen/dim_0"
                        android:insetRight="@dimen/dim_0"
                        android:insetBottom="@dimen/dim_0"
                        android:minHeight="@dimen/dim_0"
                        android:minWidth="@dimen/dim_0"
                        android:text=""
                        android:textAllCaps="false"
                        android:textColor="@android:color/transparent" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/dim_0"
                android:layout_height="@dimen/dim_116"
                android:layout_marginEnd="@dimen/dim_6"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/app_card_bg"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/dim_2">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="@dimen/dim_12">

                        <ImageView
                            android:layout_width="@dimen/dim_24"
                            android:layout_height="@dimen/dim_24"
                            android:contentDescription="@string/quiz_home_button_label"
                            android:src="@drawable/ic_home_traffic_signs" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_8"
                            android:text="@string/quiz_home_button_label"
                            android:textColor="@color/settings_text_primary"
                            android:textSize="@dimen/text_14" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dim_4"
                            android:text="@string/home_quiz_helper"
                            android:textColor="@color/settings_text_secondary"
                            android:textSize="@dimen/text_12" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/quizModeButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:insetLeft="@dimen/dim_0"
                        android:insetTop="@dimen/dim_0"
                        android:insetRight="@dimen/dim_0"
                        android:insetBottom="@dimen/dim_0"
                        android:minHeight="@dimen/dim_0"
                        android:minWidth="@dimen/dim_0"
                        android:text=""
                        android:textAllCaps="false"
                        android:textColor="@android:color/transparent" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="@dimen/dim_0"
                android:layout_height="@dimen/dim_116"
                android:layout_marginStart="@dimen/dim_6"
                android:layout_weight="1" />
        </LinearLayout>
    </LinearLayout>

+</androidx.constraintlayout.widget.ConstraintLayout>
