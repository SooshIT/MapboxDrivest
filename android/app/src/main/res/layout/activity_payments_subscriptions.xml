<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dim_16"
        android:background="@drawable/bg_app_card"
        android:elevation="@dimen/dim_2"
        android:orientation="vertical"
        android:paddingStart="@dimen/dim_20"
        android:paddingTop="@dimen/dim_20"
        android:paddingEnd="@dimen/dim_20"
        android:paddingBottom="@dimen/dim_24">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/paymentsBackButton"
            style="@style/Widget.Drivest.Button.Back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_back"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_10"
            android:text="@string/payments_screen_title"
            android:textColor="@color/settings_text_primary"
            android:textSize="@dimen/text_24"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_18"
            android:text="@string/payments_section_current_plan"
            android:textColor="@color/settings_text_primary"
            android:textSize="@dimen/text_18"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/currentPlanTierValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_8"
            android:textColor="@color/settings_text_primary"
            android:textSize="@dimen/text_15"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/currentPlanExpiryValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_4"
            android:textColor="@color/settings_text_secondary"
            android:textSize="@dimen/text_14" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_20"
            android:text="@string/payments_section_plans"
            android:textColor="@color/settings_text_primary"
            android:textSize="@dimen/text_18"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/plansLoadingValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_6"
            android:text="@string/payments_loading_plans"
            android:textColor="@color/settings_text_secondary"
            android:textSize="@dimen/text_13"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_10"
            android:text="@string/payments_plan_free"
            android:textColor="@color/settings_text_primary"
            android:textSize="@dimen/text_15"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/payments_plan_free_features"
            android:textColor="@color/settings_text_secondary"
            android:textSize="@dimen/text_14" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:text="@string/payments_plan_practice_monthly"
            android:textColor="@color/settings_text_primary"
            android:textSize="@dimen/text_15"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/practicePlanPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/payments_price_practice_monthly"
            android:textColor="@color/settings_warning_text"
            android:textSize="@dimen/text_14"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/payments_plan_practice_monthly_features"
            android:textColor="@color/settings_text_secondary"
            android:textSize="@dimen/text_14" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:text="@string/payments_plan_global_annual"
            android:textColor="@color/settings_text_primary"
            android:textSize="@dimen/text_15"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/globalPlanPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/payments_price_global_annual"
            android:textColor="@color/settings_warning_text"
            android:textSize="@dimen/text_14"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/payments_plan_global_annual_features"
            android:textColor="@color/settings_text_secondary"
            android:textSize="@dimen/text_14" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_20"
            android:text="@string/payments_section_disclosure"
            android:textColor="@color/settings_text_primary"
            android:textSize="@dimen/text_18"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_10"
            android:text="@string/payments_disclosure_auto_renew"
            android:textColor="@color/settings_text_secondary"
            android:textSize="@dimen/text_14" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_6"
            android:text="@string/payments_disclosure_cancel"
            android:textColor="@color/settings_text_secondary"
            android:textSize="@dimen/text_14" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_6"
            android:text="@string/payments_disclosure_refund"
            android:textColor="@color/settings_text_secondary"
            android:textSize="@dimen/text_14" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_20"
            android:text="@string/payments_section_actions"
            android:textColor="@color/settings_text_primary"
            android:textSize="@dimen/text_18"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/viewSubscriptionOptionsButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_10"
            android:text="@string/payments_action_view_options"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/subscribePracticeButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_8"
            android:text="@string/payments_action_subscribe_practice"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/subscribeGlobalButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_8"
            android:text="@string/payments_action_subscribe_global"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/restorePurchasesButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_8"
            android:text="@string/payments_action_restore"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/manageSubscriptionButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_8"
            android:text="@string/payments_action_manage"
            android:textAllCaps="false" />
    </LinearLayout>
</ScrollView>
