<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/dim_24">

    <ImageView
        android:id="@+id/paywallLogo"
        android:layout_width="@dimen/logo_width_home"
        android:layout_height="@dimen/logo_height_home"
        android:contentDescription="@string/drivest_logo_content_description"
        android:src="@drawable/drivest_logo_tight"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/paywallTitle"
        android:layout_width="@dimen/dim_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dim_16"
        android:gravity="center"
        android:textColor="@color/ui_hex_231F20"
        android:textSize="@dimen/text_26"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/paywallLogo" />

    <TextView
        android:id="@+id/paywallMessage"
        android:layout_width="@dimen/dim_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dim_12"
        android:gravity="center"
        android:textColor="@color/ui_hex_5A5456"
        android:textSize="@dimen/text_16"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/paywallTitle" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/paywallCloseButton"
        android:layout_width="@dimen/dim_0"
        android:layout_height="@dimen/dim_54"
        android:layout_marginTop="@dimen/dim_22"
        android:text="@string/paywall_close"
        android:textAllCaps="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/paywallMessage" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/paywallPaymentsButton"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="@dimen/dim_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dim_10"
        android:text="@string/paywall_open_payments_subscriptions"
        android:textAllCaps="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/paywallCloseButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/paywallRestoreButton"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="@dimen/dim_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dim_10"
        android:text="@string/payments_action_restore"
        android:textAllCaps="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/paywallPaymentsButton" />

</androidx.constraintlayout.widget.ConstraintLayout>
