<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/dim_10"
    app:cardBackgroundColor="@color/ui_hex_FFFFFF"
    app:cardCornerRadius="@dimen/radius_sm"
    app:cardElevation="@dimen/dim_2"
    app:strokeColor="@color/ui_hex_D8D1CE"
    app:strokeWidth="@dimen/dim_1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/dim_14"
        android:paddingTop="@dimen/dim_14"
        android:paddingEnd="@dimen/dim_14"
        android:paddingBottom="@dimen/dim_14">

        <LinearLayout
            android:layout_width="@dimen/dim_0"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/routeNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ui_hex_231F20"
                android:textSize="@dimen/text_17"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/routeMetaText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_4"
                android:textColor="@color/ui_hex_5A5456"
                android:textSize="@dimen/text_13" />
        </LinearLayout>

        <ImageView
            android:layout_width="@dimen/dim_20"
            android:layout_height="@dimen/dim_20"
            android:contentDescription="@string/practice_routes_open_map"
            android:src="@android:drawable/ic_media_next" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
