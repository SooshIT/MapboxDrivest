<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/dim_16">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/analyticsDetailBackButton"
                android:layout_width="@dimen/dim_42"
                android:layout_height="@dimen/dim_42"
                android:background="@drawable/bg_map_control_chip"
                android:contentDescription="@string/analytics_back"
                android:padding="@dimen/dim_10"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/settings_text_primary" />

            <TextView
                android:id="@+id/analyticsDetailTitle"
                android:layout_width="@dimen/dim_0"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dim_12"
                android:layout_weight="1"
                android:textColor="@color/settings_text_primary"
                android:textSize="@dimen/text_22"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/analyticsDetailSpinner"
            android:layout_width="@dimen/dim_36"
            android:layout_height="@dimen/dim_36"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/dim_24"
            android:indeterminate="true" />

        <!-- Content inflated programmatically -->
        <LinearLayout
            android:id="@+id/analyticsDetailContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_14"
            android:layout_marginBottom="@dimen/dim_24"
            android:orientation="vertical"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
