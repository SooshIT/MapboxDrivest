<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/dim_20">

    <ImageView
        android:id="@+id/practiceRoutesLogo"
        android:layout_width="@dimen/logo_width_screen"
        android:layout_height="@dimen/logo_height_screen"
        android:contentDescription="@string/drivest_logo_content_description"
        android:src="@drawable/drivest_logo_tight"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/practiceRoutesTitle"
        android:layout_width="@dimen/dim_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dim_8"
        android:text="@string/practice_routes_title_fallback"
        android:textColor="@color/ui_hex_231F20"
        android:textSize="@dimen/text_24"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/practiceRoutesLogo" />

    <TextView
        android:id="@+id/practiceRoutesSubtitle"
        android:layout_width="@dimen/dim_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dim_6"
        android:textColor="@color/ui_hex_5A5456"
        android:textSize="@dimen/text_14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/practiceRoutesTitle" />

    <TextView
        android:id="@+id/practiceOfflineBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dim_8"
        android:background="@color/ui_hex_FDE6D8"
        android:paddingStart="@dimen/dim_10"
        android:paddingTop="@dimen/dim_4"
        android:paddingEnd="@dimen/dim_10"
        android:paddingBottom="@dimen/dim_4"
        android:text="@string/practice_offline_badge"
        android:textColor="@color/ui_hex_A94A17"
        android:textSize="@dimen/text_11"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/practiceRoutesSubtitle" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/practiceRoutesRecyclerView"
        android:layout_width="@dimen/dim_0"
        android:layout_height="@dimen/dim_0"
        android:layout_marginTop="@dimen/dim_12"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/dim_16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/practiceOfflineBadge" />

    <TextView
        android:id="@+id/emptyRoutesView"
        android:layout_width="@dimen/dim_0"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/practice_routes_empty"
        android:textColor="@color/ui_hex_7A7376"
        android:textSize="@dimen/text_15"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/practiceRoutesRecyclerView"
        app:layout_constraintEnd_toEndOf="@id/practiceRoutesRecyclerView"
        app:layout_constraintStart_toStartOf="@id/practiceRoutesRecyclerView"
        app:layout_constraintTop_toTopOf="@id/practiceRoutesRecyclerView" />

</androidx.constraintlayout.widget.ConstraintLayout>
