<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/dim_8">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dim_220"
            android:background="@drawable/bg_theory_panel"
            android:padding="@dimen/dim_16">

            <ImageView
                android:id="@+id/trafficSignDetailImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="@string/traffic_signs_sign_image"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <TextView
            android:id="@+id/trafficSignDetailCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:textColor="@color/theory_text_primary"
            android:textSize="@dimen/text_18"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/trafficSignDetailMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_6"
            android:textColor="@color/theory_text_secondary"
            android:textSize="@dimen/text_13" />

        <TextView
            android:id="@+id/trafficSignDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_10"
            android:textColor="@color/theory_text_primary"
            android:textSize="@dimen/text_14" />
    </LinearLayout>

</ScrollView>
