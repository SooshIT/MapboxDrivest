<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/dim_16">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/highwayCodeBackButton"
                android:layout_width="@dimen/dim_42"
                android:layout_height="@dimen/dim_42"
                android:background="@drawable/bg_map_control_chip"
                android:contentDescription="@string/highway_code_back"
                android:padding="@dimen/dim_10"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/settings_text_primary" />

            <TextView
                android:layout_width="@dimen/dim_0"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dim_12"
                android:layout_weight="1"
                android:text="@string/highway_code_title"
                android:textColor="@color/settings_text_primary"
                android:textSize="@dimen/text_26"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/highwayCodeSourceButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dim_40"
                android:text="@string/highway_code_source_button"
                android:textAllCaps="false"
                android:textSize="@dimen/text_12" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:background="@drawable/bg_analytics_hero"
            android:orientation="vertical"
            android:padding="@dimen/dim_16">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/highway_code_hero_title"
                android:textColor="@color/ui_hex_FFFFFF"
                android:textSize="@dimen/text_20"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_6"
                android:text="@string/highway_code_hero_subtitle"
                android:textColor="@color/ui_hex_E5ECFF"
                android:textSize="@dimen/text_13" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_12"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/highwayCodeQuestionsChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_analytics_hero_chip"
                    android:paddingStart="@dimen/dim_10"
                    android:paddingTop="@dimen/dim_5"
                    android:paddingEnd="@dimen/dim_10"
                    android:paddingBottom="@dimen/dim_5"
                    android:text="@string/highway_code_chip_questions_default"
                    android:textColor="@color/ui_hex_FFFFFF"
                    android:textSize="@dimen/text_12" />

                <TextView
                    android:id="@+id/highwayCodeCategoriesChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dim_8"
                    android:background="@drawable/bg_analytics_hero_chip"
                    android:paddingStart="@dimen/dim_10"
                    android:paddingTop="@dimen/dim_5"
                    android:paddingEnd="@dimen/dim_10"
                    android:paddingBottom="@dimen/dim_5"
                    android:text="@string/highway_code_chip_categories_default"
                    android:textColor="@color/ui_hex_FFFFFF"
                    android:textSize="@dimen/text_12" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_8"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/highwayCodeSessionChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_analytics_hero_chip"
                    android:paddingStart="@dimen/dim_10"
                    android:paddingTop="@dimen/dim_5"
                    android:paddingEnd="@dimen/dim_10"
                    android:paddingBottom="@dimen/dim_5"
                    android:text="@string/highway_code_chip_session_default"
                    android:textColor="@color/ui_hex_FFFFFF"
                    android:textSize="@dimen/text_12" />

                <TextView
                    android:id="@+id/highwayCodeModeStatsChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dim_8"
                    android:background="@drawable/bg_analytics_hero_chip"
                    android:paddingStart="@dimen/dim_10"
                    android:paddingTop="@dimen/dim_5"
                    android:paddingEnd="@dimen/dim_10"
                    android:paddingBottom="@dimen/dim_5"
                    android:text="@string/highway_code_chip_mode_default"
                    android:textColor="@color/ui_hex_FFFFFF"
                    android:textSize="@dimen/text_12" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:background="@drawable/bg_app_card"
            android:orientation="vertical"
            android:padding="@dimen/dim_14">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/highway_code_scope_title"
                android:textColor="@color/settings_text_primary"
                android:textSize="@dimen/text_15"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/highwayCodeCategoryChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_8"
                app:chipSpacingHorizontal="@dimen/dim_8"
                app:chipSpacingVertical="@dimen/dim_8"
                app:singleSelection="true" />

            <TextView
                android:id="@+id/highwayCodeCategorySummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_8"
                android:text="@string/highway_code_scope_summary_default"
                android:textColor="@color/settings_text_secondary"
                android:textSize="@dimen/text_12" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:background="@drawable/bg_app_card"
            android:orientation="vertical"
            android:padding="@dimen/dim_14">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/highway_code_mode_title"
                android:textColor="@color/settings_text_primary"
                android:textSize="@dimen/text_15"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_8"
                android:background="@drawable/bg_settings_segment_track"
                android:orientation="horizontal"
                android:padding="@dimen/dim_4">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/highwayCodeModeChallenge"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="@dimen/dim_44"
                    android:layout_weight="1"
                    android:text="@string/highway_code_mode_challenge"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_12" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/highwayCodeModeSprint"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="@dimen/dim_44"
                    android:layout_marginStart="@dimen/dim_4"
                    android:layout_weight="1"
                    android:text="@string/highway_code_mode_sprint"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_12" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/highwayCodeModeReview"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="@dimen/dim_44"
                    android:layout_marginStart="@dimen/dim_4"
                    android:layout_weight="1"
                    android:text="@string/highway_code_mode_review"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_12" />
            </LinearLayout>

            <TextView
                android:id="@+id/highwayCodeModeDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_8"
                android:text="@string/highway_code_mode_description_challenge"
                android:textColor="@color/settings_text_secondary"
                android:textSize="@dimen/text_12" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/highwayCodeQuestionPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:background="@drawable/bg_app_card"
            android:orientation="vertical"
            android:padding="@dimen/dim_14">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/highwayCodeQuestionIndex"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_app_chip"
                    android:paddingStart="@dimen/dim_8"
                    android:paddingTop="@dimen/dim_4"
                    android:paddingEnd="@dimen/dim_8"
                    android:paddingBottom="@dimen/dim_4"
                    android:text="@string/highway_code_question_index_default"
                    android:textColor="@color/app_chip_text"
                    android:textSize="@dimen/text_11"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/highwayCodeQuestionCategoryChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dim_8"
                    android:background="@drawable/bg_app_chip"
                    android:paddingStart="@dimen/dim_8"
                    android:paddingTop="@dimen/dim_4"
                    android:paddingEnd="@dimen/dim_8"
                    android:paddingBottom="@dimen/dim_4"
                    android:text="@string/highway_code_category_default"
                    android:textColor="@color/app_chip_text"
                    android:textSize="@dimen/text_11"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/highwayCodeDifficultyChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dim_8"
                    android:background="@drawable/bg_app_chip"
                    android:paddingStart="@dimen/dim_8"
                    android:paddingTop="@dimen/dim_4"
                    android:paddingEnd="@dimen/dim_8"
                    android:paddingBottom="@dimen/dim_4"
                    android:text="@string/highway_code_difficulty_easy"
                    android:textColor="@color/app_chip_text"
                    android:textSize="@dimen/text_11"
                    android:textStyle="bold" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/highwayCodeProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dim_6"
                android:layout_marginTop="@dimen/dim_10"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/settings_accent"
                android:secondaryProgressTint="@color/settings_accent_soft" />

            <TextView
                android:id="@+id/highwayCodePrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_10"
                android:textColor="@color/settings_text_secondary"
                android:textSize="@dimen/text_13" />

            <TextView
                android:id="@+id/highwayCodeQuestionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_6"
                android:textColor="@color/settings_text_primary"
                android:textSize="@dimen/text_20"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_12"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/highwayCodeOption1"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/dim_52"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/highwayCodeOption2"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dim_8"
                    android:minHeight="@dimen/dim_52"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/highwayCodeOption3"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dim_8"
                    android:minHeight="@dimen/dim_52"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/highwayCodeOption4"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dim_8"
                    android:minHeight="@dimen/dim_52"
                    android:textAllCaps="false" />
            </LinearLayout>

            <TextView
                android:id="@+id/highwayCodeFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_12"
                android:textColor="@color/settings_text_primary"
                android:textSize="@dimen/text_14"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/highwayCodeExplanation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_6"
                android:textColor="@color/settings_text_secondary"
                android:textSize="@dimen/text_13"
                android:visibility="gone" />

            <TextView
                android:id="@+id/highwayCodeSourceHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_6"
                android:textColor="@color/settings_text_muted"
                android:textSize="@dimen/text_12"
                android:visibility="gone" />

            <TextView
                android:id="@+id/highwayCodeScoreLine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_12"
                android:textColor="@color/settings_text_secondary"
                android:textSize="@dimen/text_13" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_12"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/highwayCodeSecondaryActionButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="@dimen/dim_48"
                    android:layout_weight="1"
                    android:text="@string/highway_code_action_reveal"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/highwayCodePrimaryActionButton"
                    style="?attr/materialButtonStyle"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="@dimen/dim_48"
                    android:layout_marginStart="@dimen/dim_8"
                    android:layout_weight="1"
                    android:text="@string/highway_code_action_next"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/highwayCodeEmptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_16"
            android:gravity="center"
            android:text="@string/highway_code_no_questions_for_filter"
            android:textColor="@color/settings_text_secondary"
            android:textSize="@dimen/text_14"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_16"
            android:layout_marginBottom="@dimen/dim_8"
            android:text="@string/highway_code_footer_note"
            android:textColor="@color/settings_text_muted"
            android:textSize="@dimen/text_12" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
