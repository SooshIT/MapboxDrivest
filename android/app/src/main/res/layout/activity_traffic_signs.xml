<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/trafficSignsRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/dim_16">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/trafficSignsBackButton"
                android:layout_width="@dimen/dim_42"
                android:layout_height="@dimen/dim_42"
                android:background="@drawable/bg_map_control_chip"
                android:contentDescription="@string/traffic_signs_back"
                android:padding="@dimen/dim_10"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/map_control_settings_icon" />

            <TextView
                android:id="@+id/trafficSignsTopTitle"
                android:layout_width="@dimen/dim_0"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dim_10"
                android:layout_weight="1"
                android:text="@string/traffic_signs_title"
                android:textColor="@color/theory_text_primary"
                android:textSize="@dimen/text_20"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/trafficSignsSourceButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dim_40"
                android:text="@string/traffic_signs_source_short"
                android:textAllCaps="false"
                android:textSize="@dimen/text_12" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:background="@drawable/bg_theory_panel"
            android:elevation="@dimen/dim_3"
            android:outlineProvider="background"
            android:orientation="vertical"
            android:padding="@dimen/dim_16">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/trafficSignsHeaderIcon"
                    android:layout_width="@dimen/dim_52"
                    android:layout_height="@dimen/dim_52"
                    android:contentDescription="@string/traffic_signs_uk_flag_icon_content_description"
                    android:src="@drawable/ic_home_traffic_signs" />

                <LinearLayout
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dim_12"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/trafficSignsHeroTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/traffic_signs_title"
                        android:textColor="@color/theory_text_primary"
                        android:textSize="@dimen/text_24"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/trafficSignsHeroSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dim_4"
                        android:text="@string/traffic_signs_subtitle"
                        android:textColor="@color/theory_text_secondary"
                        android:textSize="@dimen/text_13" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/trafficSignsSourceNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_10"
                android:text="@string/traffic_signs_source_note"
                android:textColor="@color/theory_text_secondary"
                android:textSize="@dimen/text_12" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_12"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/trafficSignsCountChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_app_chip"
                    android:paddingStart="@dimen/dim_10"
                    android:paddingTop="@dimen/dim_6"
                    android:paddingEnd="@dimen/dim_10"
                    android:paddingBottom="@dimen/dim_6"
                    android:text="@string/traffic_signs_count_default"
                    android:textColor="@color/app_chip_text"
                    android:textSize="@dimen/text_12"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/trafficSignsCategoryChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dim_8"
                    android:background="@drawable/bg_app_chip"
                    android:paddingStart="@dimen/dim_10"
                    android:paddingTop="@dimen/dim_6"
                    android:paddingEnd="@dimen/dim_10"
                    android:paddingBottom="@dimen/dim_6"
                    android:text="@string/traffic_signs_categories_default"
                    android:textColor="@color/app_chip_text"
                    android:textSize="@dimen/text_12"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/trafficSignsSessionScoreChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dim_8"
                    android:background="@drawable/bg_app_chip"
                    android:paddingStart="@dimen/dim_10"
                    android:paddingTop="@dimen/dim_6"
                    android:paddingEnd="@dimen/dim_10"
                    android:paddingBottom="@dimen/dim_6"
                    android:text="@string/traffic_signs_quiz_score_default"
                    android:textColor="@color/app_chip_text"
                    android:textSize="@dimen/text_12"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:background="@drawable/bg_app_card"
            android:elevation="@dimen/dim_2"
            android:outlineProvider="background"
            android:orientation="vertical"
            android:padding="@dimen/dim_14">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/traffic_signs_filter_heading"
                android:textColor="@color/theory_text_primary"
                android:textSize="@dimen/text_15"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_10"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/trafficSignsCategoryFilterGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:singleSelection="true" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/trafficSignsFilterSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_8"
                android:text="@string/traffic_signs_filter_summary_default"
                android:textColor="@color/theory_text_secondary"
                android:textSize="@dimen/text_12" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:background="@drawable/bg_app_card"
            android:elevation="@dimen/dim_2"
            android:outlineProvider="background"
            android:orientation="vertical"
            android:padding="@dimen/dim_14">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/traffic_signs_mode_heading"
                android:textColor="@color/theory_text_primary"
                android:textSize="@dimen/text_15"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_10"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/trafficSignsModeFlashcards"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="@dimen/dim_44"
                    android:layout_weight="1"
                    android:text="@string/traffic_signs_mode_flashcards"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_12" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/trafficSignsModeQuiz"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="@dimen/dim_44"
                    android:layout_marginStart="@dimen/dim_8"
                    android:layout_weight="1"
                    android:text="@string/traffic_signs_mode_quiz"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_12" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/trafficSignsModeBrowse"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="@dimen/dim_44"
                    android:layout_marginStart="@dimen/dim_8"
                    android:layout_weight="1"
                    android:text="@string/traffic_signs_mode_browse"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_12" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/trafficSignsFlashcardsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:background="@drawable/bg_app_card"
            android:elevation="@dimen/dim_2"
            android:outlineProvider="background"
            android:orientation="vertical"
            android:padding="@dimen/dim_16">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/traffic_signs_flashcard_heading"
                android:textColor="@color/theory_text_primary"
                android:textSize="@dimen/text_18"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/dim_200"
                android:layout_marginTop="@dimen/dim_12"
                android:background="@drawable/bg_theory_panel"
                android:padding="@dimen/dim_14">

                <ImageView
                    android:id="@+id/trafficSignsFlashcardImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/traffic_signs_sign_image"
                    android:scaleType="fitCenter" />
            </FrameLayout>

            <TextView
                android:id="@+id/trafficSignsFlashcardCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_12"
                android:textColor="@color/theory_text_primary"
                android:textSize="@dimen/text_16"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/trafficSignsFlashcardMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_4"
                android:textColor="@color/theory_text_secondary"
                android:textSize="@dimen/text_13" />

            <TextView
                android:id="@+id/trafficSignsFlashcardMeaning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_10"
                android:background="@drawable/bg_app_chip"
                android:padding="@dimen/dim_12"
                android:textColor="@color/theory_text_primary"
                android:textSize="@dimen/text_14"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_12"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/trafficSignsFlashcardRevealButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="@dimen/dim_44"
                    android:layout_weight="1"
                    android:text="@string/traffic_signs_reveal_meaning"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/trafficSignsFlashcardKnownButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="@dimen/dim_44"
                    android:layout_marginStart="@dimen/dim_8"
                    android:layout_weight="1"
                    android:text="@string/traffic_signs_mark_known"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/trafficSignsFlashcardNextButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="@dimen/dim_0"
                    android:layout_height="@dimen/dim_44"
                    android:layout_marginStart="@dimen/dim_8"
                    android:layout_weight="1"
                    android:text="@string/traffic_signs_next_sign"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/trafficSignsQuizPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:background="@drawable/bg_app_card"
            android:elevation="@dimen/dim_2"
            android:outlineProvider="background"
            android:orientation="vertical"
            android:padding="@dimen/dim_16"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/traffic_signs_quiz_heading"
                android:textColor="@color/theory_text_primary"
                android:textSize="@dimen/text_18"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/trafficSignsQuizPrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_8"
                android:text="@string/traffic_signs_quiz_prompt_default"
                android:textColor="@color/theory_text_secondary"
                android:textSize="@dimen/text_13" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/dim_180"
                android:layout_marginTop="@dimen/dim_10"
                android:background="@drawable/bg_theory_panel"
                android:padding="@dimen/dim_12">

                <ImageView
                    android:id="@+id/trafficSignsQuizImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/traffic_signs_sign_image"
                    android:scaleType="fitCenter" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/trafficSignsQuizOption1"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_10"
                android:minHeight="@dimen/dim_44"
                android:textAllCaps="false"
                android:textSize="@dimen/text_13" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/trafficSignsQuizOption2"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_8"
                android:minHeight="@dimen/dim_44"
                android:textAllCaps="false"
                android:textSize="@dimen/text_13" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/trafficSignsQuizOption3"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_8"
                android:minHeight="@dimen/dim_44"
                android:textAllCaps="false"
                android:textSize="@dimen/text_13" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/trafficSignsQuizOption4"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_8"
                android:minHeight="@dimen/dim_44"
                android:textAllCaps="false"
                android:textSize="@dimen/text_13" />

            <TextView
                android:id="@+id/trafficSignsQuizFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_10"
                android:textColor="@color/theory_text_primary"
                android:textSize="@dimen/text_14"
                android:textStyle="bold"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/trafficSignsQuizNextButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dim_48"
                android:layout_marginTop="@dimen/dim_10"
                android:text="@string/traffic_signs_next_question"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/trafficSignsBrowsePanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_12"
            android:background="@drawable/bg_app_card"
            android:elevation="@dimen/dim_2"
            android:outlineProvider="background"
            android:orientation="vertical"
            android:padding="@dimen/dim_16"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/traffic_signs_browse_heading"
                android:textColor="@color/theory_text_primary"
                android:textSize="@dimen/text_18"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/trafficSignsSearchInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_10"
                android:hint="@string/traffic_signs_search_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/trafficSignsSearchInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@color/settings_text_primary"
                    android:textColorHint="@color/settings_text_secondary" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/trafficSignsBrowseResultCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_8"
                android:text="@string/traffic_signs_browse_results_default"
                android:textColor="@color/theory_text_secondary"
                android:textSize="@dimen/text_12" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/trafficSignsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dim_380"
                android:layout_marginTop="@dimen/dim_10"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/dim_6" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/trafficSignsLoadMoreButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dim_44"
                android:layout_marginTop="@dimen/dim_8"
                android:text="@string/traffic_signs_load_more"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>

</ScrollView>
