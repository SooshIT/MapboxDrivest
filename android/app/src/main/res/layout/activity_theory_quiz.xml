<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/dim_16">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_theory_panel"
            android:elevation="@dimen/dim_3"
            android:outlineProvider="background"
            android:orientation="vertical"
            android:padding="@dimen/dim_18">

            <TextView
                android:id="@+id/theoryQuizTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/theory_quiz_title"
                android:textColor="@color/theory_text_primary"
                android:textSize="@dimen/text_23"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/theoryQuizProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_8"
                android:background="@drawable/bg_app_chip"
                android:paddingStart="@dimen/dim_10"
                android:paddingTop="@dimen/dim_6"
                android:paddingEnd="@dimen/dim_10"
                android:paddingBottom="@dimen/dim_6"
                android:text="@string/theory_quiz_progress_default"
                android:textColor="@color/app_chip_text"
                android:textSize="@dimen/text_13"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/theoryQuizQuestionPrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_14"
                android:textColor="@color/theory_text_primary"
                android:textSize="@dimen/text_19"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/theoryQuizOptionsGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_12"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/theoryQuizOptionA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dim_8"
                    android:background="@drawable/bg_theory_option"
                    android:buttonTint="@color/theory_accent"
                    android:minHeight="@dimen/dim_54"
                    android:paddingStart="@dimen/dim_14"
                    android:paddingTop="@dimen/dim_12"
                    android:paddingEnd="@dimen/dim_14"
                    android:paddingBottom="@dimen/dim_12"
                    android:textColor="@color/theory_text_primary" />

                <RadioButton
                    android:id="@+id/theoryQuizOptionB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dim_8"
                    android:background="@drawable/bg_theory_option"
                    android:buttonTint="@color/theory_accent"
                    android:minHeight="@dimen/dim_54"
                    android:paddingStart="@dimen/dim_14"
                    android:paddingTop="@dimen/dim_12"
                    android:paddingEnd="@dimen/dim_14"
                    android:paddingBottom="@dimen/dim_12"
                    android:textColor="@color/theory_text_primary" />

                <RadioButton
                    android:id="@+id/theoryQuizOptionC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dim_8"
                    android:background="@drawable/bg_theory_option"
                    android:buttonTint="@color/theory_accent"
                    android:minHeight="@dimen/dim_54"
                    android:paddingStart="@dimen/dim_14"
                    android:paddingTop="@dimen/dim_12"
                    android:paddingEnd="@dimen/dim_14"
                    android:paddingBottom="@dimen/dim_12"
                    android:textColor="@color/theory_text_primary" />

                <RadioButton
                    android:id="@+id/theoryQuizOptionD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_theory_option"
                    android:buttonTint="@color/theory_accent"
                    android:minHeight="@dimen/dim_54"
                    android:paddingStart="@dimen/dim_14"
                    android:paddingTop="@dimen/dim_12"
                    android:paddingEnd="@dimen/dim_14"
                    android:paddingBottom="@dimen/dim_12"
                    android:textColor="@color/theory_text_primary" />
            </RadioGroup>

            <TextView
                android:id="@+id/theoryQuizFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_10"
                android:textColor="@color/theory_text_secondary"
                android:textSize="@dimen/text_14" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/theoryQuizBookmarkButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dim_48"
                android:layout_marginTop="@dimen/dim_12"
                android:text="@string/theory_bookmark_question"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/theoryQuizSubmitButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dim_48"
                android:layout_marginTop="@dimen/dim_8"
                android:text="@string/theory_submit_answer"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/theoryQuizNextButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dim_48"
                android:layout_marginTop="@dimen/dim_8"
                android:text="@string/theory_next_question"
                android:textAllCaps="false"
                android:visibility="gone" />

            <TextView
                android:id="@+id/theoryQuizSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_16"
                android:textColor="@color/theory_text_primary"
                android:textSize="@dimen/text_15"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
