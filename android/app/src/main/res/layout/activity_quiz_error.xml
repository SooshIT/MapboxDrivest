<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface"
    android:padding="@dimen/dim_20">

    <LinearLayout
        android:layout_width="@dimen/dim_0"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="@dimen/dim_72"
            android:layout_height="@dimen/dim_72"
            android:layout_marginBottom="@dimen/dim_24"
            android:contentDescription="@string/quiz_error_icon_description"
            android:src="@drawable/ic_home_traffic_signs"
            android:tint="@color/settings_accent" />

        <TextView
            android:id="@+id/quizErrorMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/quiz_error_message"
            android:textColor="@color/theory_text_primary"
            android:textSize="@dimen/text_16"
            android:textStyle="bold"
            android:gravity="center"
            android:lineSpacingExtra="@dimen/dim_2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/quizErrorRetryButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dim_52"
            android:layout_marginTop="@dimen/dim_32"
            android:text="@string/quiz_error_retry"
            android:textAllCaps="false"
            android:textSize="@dimen/text_16" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
