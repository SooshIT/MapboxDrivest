<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface"
    android:padding="@dimen/dim_20">

    <TextView
        android:id="@+id/quizScoreboardTitle"
        android:layout_width="@dimen/dim_0"
        android:layout_height="wrap_content"
        android:text="@string/quiz_score_title_solo"
        android:textColor="@color/theory_text_primary"
        android:textSize="@dimen/text_24"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="@dimen/dim_0"
        android:layout_height="@dimen/dim_0"
        android:layout_marginTop="@dimen/dim_20"
        app:layout_constraintBottom_toTopOf="@id/quizScoreboardButtonsContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/quizScoreboardTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Solo Results Card -->
            <LinearLayout
                android:id="@+id/quizScoreboardSoloCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_theory_panel"
                android:elevation="@dimen/dim_3"
                android:outlineProvider="background"
                android:orientation="vertical"
                android:padding="@dimen/dim_16">

                <TextView
                    android:id="@+id/quizScoreboardScoreLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/quiz_score_label"
                    android:textColor="@color/settings_accent"
                    android:textSize="@dimen/text_12"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/quizScoreboardScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dim_4"
                    android:text="0"
                    android:textColor="@color/theory_text_primary"
                    android:textSize="@dimen/text_32"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/quizScoreboardAccuracyLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dim_16"
                    android:text="@string/quiz_score_accuracy"
                    android:textColor="@color/settings_accent"
                    android:textSize="@dimen/text_12"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/quizScoreboardAccuracy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dim_4"
                    android:text="0%"
                    android:textColor="@color/theory_text_primary"
                    android:textSize="@dimen/text_24"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/quizScoreboardCorrectLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dim_16"
                    android:text="@string/quiz_score_correct_of"
                    android:textColor="@color/settings_accent"
                    android:textSize="@dimen/text_12"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/quizScoreboardCorrect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dim_4"
                    android:text="0 / 0"
                    android:textColor="@color/theory_text_primary"
                    android:textSize="@dimen/text_18"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/quizScoreboardNewBestBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dim_12"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_app_chip"
                    android:paddingStart="@dimen/dim_8"
                    android:paddingTop="@dimen/dim_4"
                    android:paddingEnd="@dimen/dim_8"
                    android:paddingBottom="@dimen/dim_4"
                    android:text="@string/quiz_score_new_best"
                    android:textColor="@color/app_chip_text"
                    android:textSize="@dimen/text_11"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Party Results List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/quizScoreboardPartyList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_16"
                android:visibility="gone" />

            <!-- Party Winner -->
            <LinearLayout
                android:id="@+id/quizScoreboardWinnerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_16"
                android:background="@drawable/bg_theory_panel"
                android:elevation="@dimen/dim_3"
                android:outlineProvider="background"
                android:orientation="vertical"
                android:padding="@dimen/dim_16"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/quiz_score_winner"
                    android:textColor="@color/settings_accent"
                    android:textSize="@dimen/text_12"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/quizScoreboardWinnerName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dim_8"
                    android:text="Player"
                    android:textColor="@color/theory_text_primary"
                    android:textSize="@dimen/text_20"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/quizScoreboardWinnerScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dim_4"
                    android:text="0 points"
                    android:textColor="@color/theory_text_secondary"
                    android:textSize="@dimen/text_14"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:id="@+id/quizScoreboardButtonsContainer"
        android:layout_width="@dimen/dim_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dim_20"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/quizScoreboardPlayAgainButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dim_52"
            android:text="@string/quiz_score_play_again"
            android:textAllCaps="false"
            android:textSize="@dimen/text_16" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/quizScoreboardHomeButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dim_52"
            android:layout_marginTop="@dimen/dim_8"
            android:text="@string/quiz_score_home"
            android:textAllCaps="false"
            android:textSize="@dimen/text_16" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
