<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dim_8"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/analyticsRowLabel"
            android:layout_width="@dimen/dim_0"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/settings_text_primary"
            android:textSize="@dimen/text_13"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/analyticsRowValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/settings_text_secondary"
            android:textSize="@dimen/text_12" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/analyticsRowProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dim_5"
        android:layout_marginTop="@dimen/dim_5"
        android:max="100"
        android:minHeight="@dimen/dim_5"
        android:progress="0"
        android:progressTint="@color/settings_accent"
        android:progressBackgroundTint="@color/settings_segment_track" />

    <TextView
        android:id="@+id/analyticsRowSubtext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dim_4"
        android:textColor="@color/settings_text_secondary"
        android:textSize="@dimen/text_12" />

</LinearLayout>
