<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/parkingCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/dim_10"
    app:cardBackgroundColor="@color/app_card_bg"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="@dimen/dim_2"
    app:strokeColor="@color/app_card_stroke"
    app:strokeWidth="@dimen/dim_1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/dim_12">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/parkingTitle"
                android:layout_width="@dimen/dim_0"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/parking_title_placeholder"
                android:textColor="@color/ui_hex_231F20"
                android:textSize="@dimen/text_15"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/parkingDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/parking_distance_placeholder"
                android:textColor="@color/ui_hex_5A5456"
                android:textSize="@dimen/text_12" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_6"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/parkingFeeBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_app_chip"
                android:paddingStart="@dimen/dim_8"
                android:paddingTop="@dimen/dim_4"
                android:paddingEnd="@dimen/dim_8"
                android:paddingBottom="@dimen/dim_4"
                android:text="@string/parking_fee_unknown"
                android:textColor="@color/app_chip_text"
                android:textSize="@dimen/text_11"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/parkingConfidenceBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dim_6"
                android:background="@drawable/bg_app_chip"
                android:paddingStart="@dimen/dim_8"
                android:paddingTop="@dimen/dim_4"
                android:paddingEnd="@dimen/dim_8"
                android:paddingBottom="@dimen/dim_4"
                android:text="@string/parking_confidence_medium"
                android:textColor="@color/app_chip_text"
                android:textSize="@dimen/text_11"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/parkingRulesSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dim_6"
            android:text="@string/parking_rules_unknown"
            android:textColor="@color/ui_hex_5A5456"
            android:textSize="@dimen/text_12" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
