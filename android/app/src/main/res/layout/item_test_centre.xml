<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/dim_10"
    app:cardBackgroundColor="@color/ui_hex_FFFFFF"
    app:cardCornerRadius="@dimen/radius_sm"
    app:cardElevation="@dimen/dim_2"
    app:strokeColor="@color/ui_hex_D8D1CE"
    app:strokeWidth="@dimen/dim_1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/dim_14"
        android:paddingTop="@dimen/dim_14"
        android:paddingEnd="@dimen/dim_14"
        android:paddingBottom="@dimen/dim_14">

        <LinearLayout
            android:layout_width="@dimen/dim_0"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/centreNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ui_hex_231F20"
                android:textSize="@dimen/text_17"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/centreAddressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_4"
                android:textColor="@color/ui_hex_5A5456"
                android:textSize="@dimen/text_13" />

            <TextView
                android:id="@+id/centreOfflineBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dim_8"
                android:background="@color/ui_hex_FDE6D8"
                android:paddingStart="@dimen/dim_8"
                android:paddingTop="@dimen/dim_3"
                android:paddingEnd="@dimen/dim_8"
                android:paddingBottom="@dimen/dim_3"
                android:text="@string/centre_picker_offline_badge"
                android:textColor="@color/ui_hex_A94A17"
                android:textSize="@dimen/text_11"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/centreDownloadButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:insetTop="@dimen/dim_0"
                android:insetBottom="@dimen/dim_0"
                android:minHeight="@dimen/dim_34"
                android:paddingStart="@dimen/dim_10"
                android:paddingEnd="@dimen/dim_10"
                android:text="@string/centre_picker_download_offline"
                android:textAllCaps="false"
                android:textSize="@dimen/text_12"
                app:cornerRadius="@dimen/radius_lg" />

            <ImageView
                android:id="@+id/centreOpenIcon"
                android:layout_width="@dimen/dim_20"
                android:layout_height="@dimen/dim_20"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/dim_10"
                android:contentDescription="@string/centre_picker_open_routes"
                android:src="@android:drawable/ic_media_next" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
